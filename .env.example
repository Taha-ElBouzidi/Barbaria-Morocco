# Production origin. Drives every canonical, sitemap entry, OG meta,
# robots.txt, and JSON-LD URL. Set per environment in Vercel (Production
# + Preview). The compiled fallback points to the production domain so
# stray previews still render coherent metadata.
NEXT_PUBLIC_BASE_URL=https://barbariamorocco.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://jnparcnvkghiuryarbac.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_17a3e7YmEzCFbLLbkVkgEA_e4HpqpDq

# Server-only (Vercel: set in Production + Preview environments)
SUPABASE_SERVICE_ROLE_KEY=__set_in_vercel__

# Direct Postgres connection (for Drizzle migrations + seed scripts only, never used by app runtime)
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.jnparcnvkghiuryarbac:[REPLACE_WITH_PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# First-admin bootstrap. When admin_users is empty AND a magic-link sign-in
# arrives with this email, the callback auto-creates the admin_users row.
# After bootstrap, this can be unset (subsequent admins added via /admin UI).
BOOTSTRAP_ADMIN_EMAIL=__set_to_first_admin_email__

# Resend (transactional email — inquiry receipts, admin notifications).
# Get the key from resend.com after verifying mail.barbariamorocco.com.
# Default sender is Resend's sandbox until the domain is verified, then
# switch RESEND_FROM_EMAIL to a verified address on mail.barbariamorocco.com.
RESEND_API_KEY=__set_in_vercel__
RESEND_FROM_EMAIL="Barbaria <onboarding@resend.dev>"
RESEND_NOTIFY_TO=contact@barbariamorocco.com
